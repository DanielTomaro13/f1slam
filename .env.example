# Copy to web/.env.local for local dev (all optional).

# Canonical site URL used for SEO/OG tags. Defaults to https://f1slam.com.
# NEXT_PUBLIC_SITE_URL=https://f1slam.com

# Global leaderboard Worker URL (see /worker). If unset, scores are saved
# per-browser in localStorage and everything still works.
# NEXT_PUBLIC_LEADERBOARD_URL=https://api.f1slam.com

# Set only when hosting under a sub-path (e.g. GitHub Pages project sites).
# Leave empty for the root domain.
# NEXT_PUBLIC_BASE_PATH=
